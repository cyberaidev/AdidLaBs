# AdidLaBs frontend environment — copy to .env.local and fill in after deploy.
# Concept demo — no affiliation with adidas AG. All products fictional.

# Base URL of the API Gateway HTTP API (no trailing slash), e.g. https://abc123.execute-api.ap-southeast-2.amazonaws.com
VITE_API_URL=

# Cognito User Pool id (AgentCore Identity IdP), region ap-southeast-2, e.g. ap-southeast-2_XXXXXXXXX
VITE_USER_POOL_ID=

# Cognito User Pool App Client id (public SPA client, no secret)
VITE_USER_POOL_CLIENT_ID=
